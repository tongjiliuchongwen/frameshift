{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-reframer.local/schemas/leverage_points.schema.json",
  "title": "Research Reframer Leverage Points",
  "type": "object",
  "required": ["schema_version", "source_system", "leverage_points", "selection_guidance"],
  "properties": {
    "schema_version": { "const": "2.0" },
    "source_system": { "type": "string", "minLength": 1 },
    "selection_guidance": { "type": "string", "minLength": 1 },
    "leverage_points": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "system_location",
          "source_trace",
          "why_it_matters",
          "current_assumption",
          "reframing_potential",
          "risk",
          "human_selectable"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^LP-[0-9]{3}$" },
          "type": {
            "enum": [
              "parameter",
              "buffer",
              "structure",
              "delay",
              "feedback_loop",
              "information_flow",
              "rule",
              "self_organization",
              "goal",
              "paradigm"
            ]
          },
          "system_location": { "type": "string", "minLength": 1 },
          "source_trace": {
            "type": "object",
            "required": ["system_node_ids", "input_evidence"],
            "properties": {
              "system_node_ids": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              },
              "input_evidence": { "type": "string", "minLength": 1 }
            }
          },
          "why_it_matters": { "type": "string", "minLength": 1 },
          "current_assumption": { "type": "string", "minLength": 1 },
          "reframing_potential": { "enum": ["high", "medium", "low"] },
          "risk": { "type": "string", "minLength": 1 },
          "human_selectable": { "type": "boolean" }
        }
      }
    }
  }
}
